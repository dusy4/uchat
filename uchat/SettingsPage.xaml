    <Page
    x:Class="uchat.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#4CAF50"/>
        <SolidColorBrush x:Key="DangerRed" Color="#F44336"/>
        <FontFamily x:Key="MainFont">Segoe UI Variable Display</FontFamily>

        <Color x:Key="Dark_BackgroundDarkerColor">#0F0F0F</Color>
        <Color x:Key="Dark_CardBackgroundColor">#141918</Color>
        <Color x:Key="Dark_TextWhiteColor">#FFFFFF</Color>
        <Color x:Key="Dark_TextGrayColor">#8B9A95</Color>
        <Color x:Key="Dark_BorderDarkColor">#2A2A2A</Color>

        <Color x:Key="Light_BackgroundDarkerColor">#FFFFFF</Color>
        <Color x:Key="Light_CardBackgroundColor">#FFFFFF</Color>
        <Color x:Key="Light_TextWhiteColor">#111111</Color>
        <Color x:Key="Light_TextGrayColor">#666666</Color>
        <Color x:Key="Light_BorderDarkColor">#D1D9E6</Color>

        <SolidColorBrush x:Key="Current_BackgroundDarker" Color="{StaticResource Dark_BackgroundDarkerColor}"/>
        <SolidColorBrush x:Key="Current_CardBackground" Color="{StaticResource Dark_CardBackgroundColor}"/>
        <SolidColorBrush x:Key="Current_TextWhite" Color="{StaticResource Dark_TextWhiteColor}"/>
        <SolidColorBrush x:Key="Current_TextGray" Color="{StaticResource Dark_TextGrayColor}"/>
        <SolidColorBrush x:Key="Current_BorderDark" Color="{StaticResource Dark_BorderDarkColor}"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Padding="24">
                <StackPanel Spacing="24">
                    <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>

                    <Border Background="{StaticResource Current_CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>
                            <TextBlock Text="Toggle between light and dark theme" FontSize="13" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}"/>

                            <Button x:Name="ThemeToggleButton"
                                    Click="ThemeToggleButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"
                                    Background="{StaticResource Current_BackgroundDarker}"
                                    Foreground="{StaticResource Current_TextWhite}"
                                    BorderBrush="{StaticResource Current_BorderDark}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,10">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon x:Name="ThemeIcon" Glyph="&#xE706;" FontSize="18"/>
                                    <TextBlock x:Name="ThemeText" Text="Dark Mode" FontSize="15" FontWeight="SemiBold" FontFamily="{StaticResource MainFont}"/>
                                </StackPanel>
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_CardBackground}}"/>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Current_CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Notifications" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>
                            <TextBlock Text="Choose when you want to receive desktop notifications" FontSize="13" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}"/>
                            <ComboBox x:Name="NotificationModeBox" HorizontalAlignment="Stretch" SelectionChanged="NotificationModeBox_SelectionChanged" Background="{StaticResource Current_BackgroundDarker}" Foreground="{StaticResource Current_TextWhite}" BorderBrush="{StaticResource Current_BorderDark}">
                                <ComboBoxItem Content="All Messages" Tag="All"/>
                                <ComboBoxItem Content="Mentions &amp; Private Only" Tag="Mentions"/>
                                <ComboBoxItem Content="None" Tag="None"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Current_CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Data &amp; Storage" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>

                            <TextBlock Text="Auto-Download Files" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>

                            <ToggleSwitch x:Name="AutoDownloadToggle" 
                             OffContent="Off" OnContent="On" 
                             Toggled="AutoDownloadToggle_Toggled"
                             Foreground="{StaticResource Current_TextWhite}"/>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="PickFolderButton" 
                           Content="Choose Folder" 
                           Click="PickFolder_Click"
                           IsEnabled="{x:Bind AutoDownloadToggle.IsOn, Mode=OneWay}"
                           CornerRadius="8"
                           Background="{StaticResource Current_BackgroundDarker}" 
                           Foreground="{StaticResource Current_TextWhite}" 
                           BorderBrush="{StaticResource Current_BorderDark}" 
                           BorderThickness="1"/>

                                <TextBlock x:Name="FolderPathText" 
                              Text="No folder selected" 
                              VerticalAlignment="Center" 
                              Foreground="{StaticResource Current_TextGray}" 
                              FontSize="12"
                              TextTrimming="CharacterEllipsis" 
                              MaxWidth="200"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Current_CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Security" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>

                            <PasswordBox x:Name="OldPasswordBox" 
                                         Header="Old Password" 
                                         PlaceholderText="Current password"/>

                            <PasswordBox x:Name="NewPasswordBox" 
                                         Header="New Password" 
                                         PlaceholderText="Min 6 characters"/>

                            <PasswordBox x:Name="ConfirmPasswordBox" 
                                         Header="Confirm New Password" 
                                         PlaceholderText="Re-enter new password"/>

                            <Button x:Name="ChangePasswordButton"
                                    Content="Update Password"
                                    Click="ChangePasswordButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"
                                    Background="{StaticResource Current_BackgroundDarker}"
                                    Foreground="{StaticResource Current_TextWhite}"
                                    BorderBrush="{StaticResource Current_BorderDark}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,10">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_CardBackground}}"/>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Current_CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Account" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>
                            <TextBlock Text="Manage your account settings" FontSize="13" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}"/>
                            
                            <Button x:Name="LogoutButton"
                                    Content="Log Out"
                                    Click="LogoutButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"
                                    Background="{StaticResource Current_BackgroundDarker}"
                                    Foreground="{StaticResource Current_TextWhite}"
                                    BorderBrush="{StaticResource Current_BorderDark}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,10"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    FontFamily="{StaticResource MainFont}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_CardBackground}}"/>
                                </Button.Resources>
                            </Button>
                            
                            <Button x:Name="DeleteAccountButton"
                                    Content="Delete Account"
                                    Click="DeleteAccountButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"
                                    Background="{StaticResource DangerRed}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    CornerRadius="8"
                                    Padding="16,10"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    FontFamily="{StaticResource MainFont}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#F44336"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E53935"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#D32F2F"/>
                                    <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

