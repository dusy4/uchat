<Page
    x:Class="uchat.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:uchat"
    xmlns:models="using:uchat.Models"  mc:Ignorable="d"
    Background="#1A1A1A">

    <Page.Resources>
        <local:UnreadCountToVisibilityConverter x:Key="UnreadVisibilityConverter"/>
        <local:SelectedToBackgroundConverter x:Key="SelectedToBackgroundConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:TextVisibilityConverter x:Key="TextVisibilityConverter"/>
        <local:VoiceVisibilityConverter x:Key="VoiceVisibilityConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:GlobalChatVisibilityConverter x:Key="GlobalChatVisibilityConverter"/>
        <local:MessageBackgroundConverter x:Key="MessageBackgroundConverter" 
                                          OwnMessageBrush="{StaticResource Current_MessageBubbleOwn}"
                                          OtherMessageBrush="{StaticResource Current_MessageBubbleOther}"/>
        
        <!-- Animated Button Style -->
        <Style x:Key="AnimatedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.8"
                                                             Duration="0:0:0.1" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.98"
                                                             Duration="0:0:0.1" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.98"
                                                             Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.7"
                                                             Duration="0:0:0.05" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.95"
                                                             Duration="0:0:0.05" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.95"
                                                             Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.5"
                                                             Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}">
                                    <ContentPresenter.RenderTransform>
                                        <ScaleTransform x:Name="ScaleTransform" />
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="EmojiItemTemplate" x:DataType="x:String">
            <Grid Width="44" Height="44" Margin="2" Background="Transparent">
                <TextBlock Text="{Binding}" 
                   FontFamily="Segoe UI Emoji" 
                   IsColorFontEnabled="True" 
                   FontSize="28" 
                   TextLineBounds="Tight" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
        <local:NotGlobalChatVisibilityConverter x:Key="NotGlobalChatConverter"/>
    </Page.Resources>
    <Viewbox x:Name="AppViewbox" Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <Grid x:Name="RootGrid">

            <Grid x:Name="TitleBarLogo" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,8,0,0" Width="32" Height="32" Visibility="Collapsed">
                <Image x:Name="TitleBarLogoImage" Source="ms-appx:///uchat_logo.png" Stretch="Uniform"/>
            </Grid>
        <Grid x:Name="LoginPanel" Canvas.ZIndex="100" Background="{StaticResource Current_BackgroundDark}">
            <Border Background="{StaticResource Current_CardBackground}" CornerRadius="16" Padding="48" HorizontalAlignment="Center" VerticalAlignment="Center" Width="420" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel Spacing="28">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Clover Chat" FontSize="52" FontWeight="Bold" Foreground="{StaticResource PrimaryGreen}" HorizontalAlignment="Center" FontFamily="{StaticResource MainFont}"/>
                        <TextBlock Text="Secure messaging for everyone" FontSize="15" Foreground="{StaticResource Current_TextGray}" HorizontalAlignment="Center" FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>
                    <StackPanel Spacing="14">
                        <TextBox x:Name="UsernameTextBox" PlaceholderText="Username" PlaceholderForeground="{StaticResource Current_Placeholder}" Height="50" CornerRadius="10" Background="{StaticResource Current_BackgroundDarker}" Foreground="{StaticResource Current_TextWhite}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1" Padding="16,13,16,0" FontSize="15" FontFamily="{StaticResource MainFont}" VerticalAlignment="Center">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                            </TextBox.Resources>
                        </TextBox>
                        <PasswordBox x:Name="PasswordBox" PlaceholderText="Password" Height="50" CornerRadius="10" Background="{StaticResource Current_BackgroundDarker}" Foreground="{StaticResource Current_TextWhite}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1" Padding="16,13,16,0" FontSize="15" FontFamily="{StaticResource MainFont}" VerticalAlignment="Center">
                            <PasswordBox.Resources>
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{Binding Color, Source={StaticResource Current_Placeholder}}"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{Binding Color, Source={StaticResource Current_Placeholder}}"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{Binding Color, Source={StaticResource Current_Placeholder}}"/>
                            </PasswordBox.Resources>
                        </PasswordBox>
                    </StackPanel>
                    <StackPanel Spacing="14">
                        <Button x:Name="LoginButton" Content="Login" Click="LoginButton_Click" HorizontalAlignment="Stretch" Height="48" Background="#4CAF50" Foreground="White" CornerRadius="10" FontWeight="Bold" FontSize="16" BorderThickness="0" FontFamily="{StaticResource MainFont}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#4CAF50"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#4CAF50"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#388E3C"/>
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#2A2A2A"/>
                                <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#666666"/>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="RegisterButton" Content="Create Account" Click="RegisterButton_Click" HorizontalAlignment="Stretch" Height="48" Background="Transparent" Foreground="#4CAF50" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="10" FontWeight="SemiBold" FontSize="15" FontFamily="{StaticResource MainFont}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#4CAF50"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#388E3C"/>
                                <SolidColorBrush x:Key="ButtonForeground" Color="#4CAF50"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#666666"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="#4CAF50"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#4CAF50"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#388E3C"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#666666"/>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock x:Name="StatusTextBlock" Foreground="#FF5555" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0" FontFamily="{StaticResource MainFont}"/>
                        <ProgressRing x:Name="LoadingRing" IsActive="False" HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,10,0,0" Foreground="{StaticResource PrimaryGreen}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid x:Name="ChatPanel" Visibility="Collapsed" Background="{StaticResource Current_BackgroundDark}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="340" MinWidth="94.4"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource Current_SidebarBackground}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="0,0,1,0">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="LogoButton" Grid.Row="0" Click="LogoButton_Click" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,16,0,0" Width="44" Height="44" Background="Transparent" BorderThickness="0" Padding="0">
                        <Image x:Name="LogoImage" Width="44" Height="44" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,16" Spacing="8">
                        <Button x:Name="MarkAllReadButton" Click="MarkAllReadButton_Click" HorizontalAlignment="Center" Width="44" Height="44" Background="{StaticResource Current_SidebarButtonBackground}" Foreground="{StaticResource Current_TextWhite}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1" CornerRadius="8" ToolTipService.ToolTip="Mark all as read">
                            <FontIcon Glyph="&#xE8FB;" FontSize="18"/>
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="{Binding Color, Source={StaticResource Current_SidebarButtonBackground}}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="SettingsButton" Click="SettingsButton_Click" HorizontalAlignment="Center" Width="44" Height="44" Background="{StaticResource Current_SidebarButtonBackground}" Foreground="{StaticResource Current_TextWhite}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1" CornerRadius="8">
                            <FontIcon Glyph="&#xE713;" FontSize="20"/>
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="{Binding Color, Source={StaticResource Current_SidebarButtonBackground}}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1"
                   Width="4"
                   Background="Transparent"
                   x:Name="LeftSplitter"
                   PointerPressed="LeftSplitter_PointerPressed"
                   PointerMoved="LeftSplitter_PointerMoved"
                   PointerReleased="LeftSplitter_PointerReleased"
                   PointerEntered="Splitter_PointerEntered"
                   PointerExited="Splitter_PointerExited"/>
            <Border Grid.Column="2" Background="{StaticResource Current_SidebarBackground}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="0,0,1,0" x:Name="ChatListBorder" CornerRadius="0,12,12,0">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource Current_CardBackground}" Padding="20,18" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="0,0,0,1" Tapped="ProfileHeader_Tapped">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="52" Height="52" CornerRadius="26">
                                <Ellipse x:Name="MyProfileEllipse" Fill="{StaticResource PrimaryGreen}"/>
                                <TextBlock x:Name="MyAvatarInitials" Text="?" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="20" FontFamily="{StaticResource MainFont}"/>
                                <Image x:Name="MyProfileImage" Stretch="UniformToFill"/>
                            </Grid>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" x:Name="ProfileInfoPanel">
                                <TextBlock x:Name="MyUsernameText" Text="Connecting..." FontSize="17" FontWeight="Bold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,0">
                                    <Ellipse Width="9" Height="9" Fill="{StaticResource PrimaryGreen}"/>
                                    <TextBlock x:Name="ConnectionStatusTextBlock" Text="Online" FontSize="13" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                        <Grid Grid.Row="1" Padding="16,14" x:Name="SearchPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="UserSearchBox" Grid.Column="0" PlaceholderText="Search users..." PlaceholderForeground="{StaticResource Current_Placeholder}" TextChanged="UserSearchBox_TextChanged" GotFocus="UserSearchBox_GotFocus" LostFocus="UserSearchBox_LostFocus" Background="{StaticResource Current_BackgroundDarker}" Foreground="{StaticResource Current_TextWhite}" BorderThickness="1" BorderBrush="{StaticResource Current_BorderDark}" CornerRadius="10" Padding="14,10" Height="44" FontSize="14" FontFamily="{StaticResource MainFont}" Margin="0,0,8,0">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                    <SolidColorBrush x:Key="TextControlForeground" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                                </TextBox.Resources>
                            </TextBox>

                            <Button Grid.Column="1" Click="CreateGroup_Click" Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource Current_BorderDark}" Height="44" Width="44" CornerRadius="10" ToolTipService.ToolTip="Create Group">
                                <FontIcon Glyph="&#xE710;" FontSize="16" Foreground="{StaticResource Current_TextWhite}"/>
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_CardBackground}}"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                </Button.Resources>
                            </Button>
                        </Grid>

                        <ListView x:Name="UsersListView" Grid.Row="2" SelectionMode="Single" SelectionChanged="UsersListView_SelectionChanged" Padding="8,0,8,10" Background="Transparent">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <ContentThemeTransition />
                                    <ReorderThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="OuterBorder" CornerRadius="8" Margin="{TemplateBinding Margin}" Background="Transparent">
                                                    <ContentPresenter x:Name="ContentPresenter" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" ContentTransitions="{TemplateBinding ContentTransitions}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>

                                                            <VisualState x:Name="PointerOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterBorder" Storyboard.TargetProperty="Background">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource HighlightGreenSubtle}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>

                                                            <VisualState x:Name="Pressed">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterBorder" Storyboard.TargetProperty="Background">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource HighlightGreenSubtle}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>

                                                        <VisualStateGroup x:Name="SelectionStates">
                                                            <VisualState x:Name="Unselected"/>

                                                            <VisualState x:Name="Selected">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterBorder" Storyboard.TargetProperty="Background">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource HighlightGreenSelected}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>

                                                            <VisualState x:Name="SelectedPointerOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterBorder" Storyboard.TargetProperty="Background">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource HighlightGreenSelected}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>

                                                            <VisualState x:Name="SelectedPressed">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterBorder" Storyboard.TargetProperty="Background">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource HighlightGreenSelected}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:UserItemModel">
                                    <Grid>
                                        <Grid.Transitions>
                                            <TransitionCollection>
                                                <EntranceThemeTransition FromHorizontalOffset="-20" FromVerticalOffset="0" IsStaggeringEnabled="True" />
                                            </TransitionCollection>
                                        </Grid.Transitions>
                                        <Border x:Name="ChatItemBorder" ContextRequested="ChatItemBorder_ContextRequested" CornerRadius="12" Padding="14,12" BorderBrush="Transparent" BorderThickness="0" Background="Transparent">
                                            <Border.Transitions>
                                                <TransitionCollection>
                                                    <RepositionThemeTransition />
                                                </TransitionCollection>
                                            </Border.Transitions>
                                            <Border.ContextFlyout>
                                                <MenuFlyout Opening="ChatMenu_Opening">
                                                    <MenuFlyoutItem Text="View Profile" Icon="Contact" Click="ViewProfile_Click" Tag="{x:Bind}" Visibility="{Binding Username, Converter={StaticResource NotGlobalChatConverter}}"/>
                                                    <MenuFlyoutSeparator Visibility="{Binding Username, Converter={StaticResource NotGlobalChatConverter}}"/>
                                                    <MenuFlyoutItem Text="{x:Bind ExitMenuText, Mode=OneWay}" Icon="Delete" Click="DeleteChat_Click" Tag="{x:Bind}" Foreground="#FF4444" Visibility="{Binding Username, Converter={StaticResource NotGlobalChatConverter}}"/>
                                                </MenuFlyout>
                                            </Border.ContextFlyout>
                                            <Grid x:Name="ChatItemContent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Grid.RowSpan="2" Width="50" Height="50" CornerRadius="25" HorizontalAlignment="Center">
                                                    <Ellipse Fill="{x:Bind AvatarColor, Mode=OneWay}"/>

                                                    <TextBlock Text="{x:Bind Initials, Mode=OneWay}" 
                                       Visibility="{x:Bind ProfileImage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                                       Foreground="White" FontWeight="Bold" FontSize="18" 
                                       FontFamily="{StaticResource MainFont}"/>

                                                    <Image Source="{x:Bind ProfileImage, Mode=OneWay}" 
                                   Visibility="{x:Bind ProfileImage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                   Stretch="UniformToFill"/>
                                                </Grid>

                                                <Grid Grid.Column="1" Grid.Row="0" x:Name="UsernameGrid">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="6">
                                                        <FontIcon Glyph="&#xE716;" FontSize="14" Foreground="{StaticResource PrimaryGreen}" VerticalAlignment="Center" Visibility="{x:Bind IsGroup, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        <FontIcon Glyph="&#xE774;" FontSize="14" Foreground="{StaticResource PrimaryGreen}" VerticalAlignment="Center" Visibility="{x:Bind Username, Mode=OneWay, Converter={StaticResource GlobalChatVisibilityConverter}}"/>
                                                        <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="1" Background="#FF4444" CornerRadius="10" Padding="6,2" MinWidth="20" HorizontalAlignment="Right" Visibility="{x:Bind UnreadCount, Mode=OneWay, Converter={StaticResource UnreadVisibilityConverter}}">
                                                        <TextBlock Text="{x:Bind UnreadCount, Mode=OneWay}" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource MainFont}"/>
                                                    </Border>
                                                </Grid>

                                                <TextBlock Grid.Column="1" Grid.Row="1" local:RichTextExtensions.Markdown="{x:Bind LastMessage, Mode=OneWay}" VerticalAlignment="Center" Margin="16,4,0,0" FontSize="13" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1" x:Name="LastMessageText"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
            </Border>
            <Border Grid.Column="3"
                   Width="4"
                   Background="Transparent"
                   x:Name="RightSplitter"
                   PointerPressed="RightSplitter_PointerPressed"
                   PointerMoved="RightSplitter_PointerMoved"
                   PointerReleased="RightSplitter_PointerReleased"
                   PointerEntered="Splitter_PointerEntered"
                   PointerExited="Splitter_PointerExited"/>
            <Grid Grid.Column="4" Background="{StaticResource Current_BackgroundDark}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource Current_CardBackground}" Padding="24,16" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock x:Name="CurrentChatTitle" Text="Clover Chat" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox x:Name="ChatSearchBox" Visibility="Collapsed" Width="200" PlaceholderText="Search in chat..." TextChanged="ChatSearchBox_TextChanged" VerticalAlignment="Center" Background="{StaticResource Current_BackgroundDarker}" Foreground="{StaticResource Current_TextWhite}" BorderBrush="{StaticResource Current_BorderDark}"/>
                                    <Button x:Name="ChatSearchButton" Click="ToggleChatSearch_Click" Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="8">
                                        <FontIcon x:Name="ChatSearchIcon" Glyph="&#xE721;" FontSize="16" Foreground="{StaticResource Current_TextGray}"/>
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <Grid Grid.Column="1" Width="140" Height="32"/>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Grid.RowSpan="2">
                        <Grid Grid.Row="1" Canvas.ZIndex="100" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,20,0">
                            <Border x:Name="ChatSearchResultsBorder" Visibility="Collapsed" Background="{StaticResource Current_CardBackground}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1" CornerRadius="0,0,8,8"  Width="300" MaxHeight="400">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="SearchResultsHeader" Grid.Row="0" Text="Found 0 messages" Foreground="{StaticResource Current_TextGray}" FontSize="12" Margin="12,8"/>
                                    <ListView x:Name="ChatSearchResultsList" Grid.Row="1" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="ChatSearchResult_Click">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="local:MessageViewModel">
                                                <Grid Padding="8,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0" Width="32" Height="32" CornerRadius="16" Margin="0,0,8,0" VerticalAlignment="Top">
                                                        <Ellipse Fill="{StaticResource PrimaryGreen}" Opacity="0.2"/>
                                                        <TextBlock Text="{Binding SenderUsername}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>

                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <TextBlock Text="{Binding SenderUsername}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource Current_TextWhite}"/>
                                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="10" Foreground="{StaticResource Current_TextGray}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Content}" FontSize="12" Foreground="{StaticResource Current_TextGray}" TextTrimming="CharacterEllipsis" MaxLines="2"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>
                        </Grid>
                        <ListView x:Name="MessagesListView" Padding="12,8,12,100" SelectionMode="None" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel ItemsUpdatingScrollMode="KeepItemsInView" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:MessageViewModel">
                                    <Grid Margin="0,2" HorizontalAlignment="{Binding HorizontalAlignment}">
                                        <Grid.Transitions>
                                            <TransitionCollection>
                                                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="20" IsStaggeringEnabled="False" />
                                            </TransitionCollection>
                                        </Grid.Transitions>
                                        <Border Background="{Binding IsOwnMessage, Converter={StaticResource MessageBackgroundConverter}}" CornerRadius="8" Padding="8,6" MaxWidth="420" MinWidth="80" BorderBrush="Transparent" BorderThickness="0">
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal" />
                                                    <VisualState x:Name="PointerOver">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="MessageBorder"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.95"
                                             Duration="0:0:0.1" />
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                            <Border x:Name="MessageBorder">
                                                <Border.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="Send Message" Icon="Send" Click="OpenPrivateChat_Click" Tag="{Binding}" Visibility="{Binding ShowOpenPrivateChat}"/>
                                                        <MenuFlyoutItem Text="View Profile" Icon="Contact" Click="ViewProfileFromMessage_Click" Tag="{Binding}" Visibility="{Binding ShowProfileOption}"/>
                                                        <MenuFlyoutSeparator Visibility="{Binding ShowProfileOption}"/>
                                                        <MenuFlyoutItem Text="Reply" Icon="Undo" Click="ReplyContext_Click" Tag="{Binding}"/>
                                                        <MenuFlyoutItem Text="Copy" Icon="Copy" Click="CopyMessage_Click" Tag="{Binding Id}" Visibility="{Binding ShowCopyOption}"/>
                                                        <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditMessage_Click" Tag="{Binding Id}" Visibility="{Binding ShowEditOption}"/>
                                                        <MenuFlyoutItem Text="Save As" Icon="Save" Click="DownloadFile_Click" Tag="{Binding}" Visibility="{Binding ShowSaveAsOption}"/>
                                                        <MenuFlyoutSubItem Text="Volume" Icon="Volume" Visibility="{Binding ShowVoicePlayer}">
                                                            <MenuFlyoutItem>
                                                                <MenuFlyoutItem.Template>
                                                                    <ControlTemplate>
                                                                        <Grid Padding="12,4">
                                                                            <Slider Value="{Binding VoiceVolumeValue, Mode=TwoWay}" 
                                                    Maximum="100" Minimum="0" Width="150"
                                                    Tag="{Binding}" 
                                                    ValueChanged="VoiceVolumeSlider_ValueChanged"/>
                                                                        </Grid>
                                                                    </ControlTemplate>
                                                                </MenuFlyoutItem.Template>
                                                            </MenuFlyoutItem>
                                                        </MenuFlyoutSubItem>
                                                        <MenuFlyoutItem Text="Delete" Icon="Delete" Click="DeleteMessage_Click" Tag="{Binding Id}" Visibility="{Binding ShowDeleteOption}"/>
                                                        <MenuFlyoutSeparator Visibility="{Binding ShowEditedTime}"/>
                                                        <MenuFlyoutItem Text="{Binding EditedTimeDisplay}" IsEnabled="False" Visibility="{Binding ShowEditedTime}" FontSize="11" Foreground="{StaticResource Current_TextGray}"/>
                                                    </MenuFlyout>
                                                </Border.ContextFlyout>

                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding SenderUsername}" Visibility="{Binding ShowSenderName}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource PrimaryGreen}" Margin="0,0,0,2" FontFamily="{StaticResource MainFont}"/>
                                                    <Button Click="Reply_Click" Tag="{Binding ReplyToId}" Visibility="{Binding ShowReplyInfo}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,0,6">
                                                        <Button.Resources>
                                                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#11FFFFFF"/>
                                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#22FFFFFF"/>
                                                        </Button.Resources>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="3"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Rectangle Grid.Column="0" Fill="{StaticResource PrimaryGreen}" RadiusX="1.5" RadiusY="1.5"/>
                                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding ReplyToSender}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryGreen}" FontFamily="{StaticResource MainFont}"/>
                                                                <TextBlock Text="{Binding ReplyPreviewText}" FontSize="12" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Grid Grid.Column="0" Margin="0,0,8,0">
                                                            <Image Source="{x:Bind StickerSource, Mode=OneWay}" Visibility="{x:Bind ShowSticker, Mode=OneWay}" Stretch="Fill" Width="250" Height="250" HorizontalAlignment="Left"></Image>
                                                            <RichTextBlock IsTextSelectionEnabled="True" Visibility="{Binding ShowText}" DataContextChanged="MessageRichTextBlock_DataContextChanged" FontSize="14" Foreground="{StaticResource Current_TextWhite}"  TextWrapping="Wrap"/>
                                                            <Image x:Name="MessageGifImage" MaxWidth="300" MaxHeight="300" Stretch="Uniform" Source="{Binding DisplayImage}" Visibility="{Binding ShowGif}"/>
                                                            <Grid Visibility="{Binding ShowImage}" MaxWidth="300" MaxHeight="400" CornerRadius="8" Margin="0,4">

                                                                <Grid Background="#2A2A2A" MinHeight="150" MinWidth="150" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{Binding ShowImageLoading}">
                                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                                                        <ProgressRing IsActive="True" Width="30" Height="30" Foreground="{StaticResource PrimaryGreen}"/>
                                                                        <TextBlock Text="Loading..." FontSize="12" Foreground="#8B9A95" HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <Button Background="Transparent" Padding="0" BorderThickness="0" Click="MessageImage_Click" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                                    <Image x:Name="MessageContentImage" Source="{Binding DisplayImage}" Stretch="Uniform"/>
                                                                </Button>
                                                            </Grid>
                                                            <Grid Visibility="{x:Bind ShowVoicePlayer}" Width="220" Margin="0,5,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Button Grid.Column="0" Click="PlayVoiceMessage_Click" Tag="{x:Bind}" Width="34" Height="34" CornerRadius="17" Padding="0" Background="{StaticResource PrimaryGreen}"  BorderThickness="0" Margin="0,0,10,0">
                                                                    <FontIcon Glyph="{x:Bind VoicePlayButtonGlyph, Mode=OneWay}" FontSize="14" Foreground="White" Margin="2,0,0,0"/>
                                                                </Button>

                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <Slider Value="{x:Bind VoiceProgressValue, Mode=OneWay}" Maximum="100" Tag="{x:Bind}"  ValueChanged="VoiceProgressSlider_ValueChanged" MinWidth="150" VerticalAlignment="Center" IsThumbToolTipEnabled="False"/>

                                                                    <TextBlock Text="{x:Bind VoiceTimeDisplay, Mode=OneWay}" 
                   FontSize="10" Foreground="{StaticResource Current_TextGray}" 
                   HorizontalAlignment="Right" Margin="0,-4,0,0"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <Grid Visibility="{Binding ShowFile}" Width="240">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,10,0">
                                                                    <Ellipse Fill="{StaticResource Current_BackgroundDarker}" Opacity="0.5"/>
                                                                    <FontIcon Glyph="&#xE7C3;" FontSize="20" Foreground="{StaticResource Current_TextWhite}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Grid>

                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                                    <TextBlock Text="{Binding FileName}" Foreground="{StaticResource Current_TextWhite}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" MaxLines="1" ToolTipService.ToolTip="{Binding FileName}"/>
                                                                    <TextBlock Text="{Binding FileSizeDisplay}" Foreground="{StaticResource Current_TextWhite}" FontSize="11" Opacity="0.7"/>
                                                                </StackPanel>

                                                                <Button Grid.Column="2" Click="DownloadFile_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Padding="8" VerticalAlignment="Center" ToolTipService.ToolTip="Download">
                                                                    <FontIcon Glyph="&#xE896;" FontSize="18" Foreground="{StaticResource Current_TextWhite}"/>
                                                                </Button>
                                                            </Grid>
                                                        </Grid>

                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" VerticalAlignment="Bottom" Margin="0,0,0,0" Visibility="{Binding ShowTimestamp}">
                                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}" Opacity="0.7"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="2" Margin="4,0,0,0" Visibility="{Binding ShowStatus}">
                                                                <TextBlock Text="{Binding StatusGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="12" CharacterSpacing="-500" Foreground="{Binding StatusColor}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid VerticalAlignment="Bottom" Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="SuggestionsBorder" Grid.Row="0" Visibility="Collapsed" Background="{StaticResource Current_CardBackground}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1" CornerRadius="8" Margin="20,0,0,5" Padding="0" HorizontalAlignment="Left" MaxHeight="200" Width="250" Canvas.ZIndex="1000">
                                <ListView x:Name="SuggestionsList" SelectionMode="Single" ItemClick="SuggestionsList_ItemClick" IsItemClickEnabled="True">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:UserItemModel">
                                            <StackPanel Orientation="Horizontal" Spacing="10" Padding="8,5">
                                                <Grid Width="24" Height="24" CornerRadius="12">
                                                    <Ellipse Fill="{Binding AvatarColor}"/>
                                                    <Image Source="{Binding ProfileImage}" Stretch="UniformToFill"/>
                                                    <TextBlock Text="{Binding Initials}" FontSize="10" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding ProfileImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                </Grid>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Current_TextWhite}"/>
                                                    <TextBlock Text="{Binding Username}" FontSize="11" Foreground="{StaticResource Current_TextGray}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>

                            <Button x:Name="GoToNewButton" Grid.Row="0" Content="Go to new messages" Click="GoToNewButton_Click" HorizontalAlignment="Right" Margin="24,8,24,0" Background="{StaticResource PrimaryGreen}" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="16,8" FontSize="13" FontFamily="{StaticResource MainFont}" Visibility="Collapsed">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource DarkGreen}}"/>
                            </Button.Resources>
                        </Button>
                            <Border x:Name="ReplyPanel" Grid.Row="0" Grid.ColumnSpan="2" Visibility="Collapsed" Background="{StaticResource Current_CardBackground}" BorderBrush="{StaticResource PrimaryGreen}" BorderThickness="3,0,0,0" Padding="12,8" Margin="0" CornerRadius="4,4,0,0" VerticalAlignment="Bottom">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE97A;" FontSize="12" Foreground="{StaticResource PrimaryGreen}"/>
                                            <TextBlock Text="Replying to" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryGreen}" FontFamily="{StaticResource MainFont}"/>
                                            <TextBlock x:Name="ReplyTargetName" Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Current_TextWhite}" FontFamily="{StaticResource MainFont}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ReplyPreviewText" Text="Message content..." FontSize="12" Foreground="{StaticResource Current_TextGray}" FontFamily="{StaticResource MainFont}" TextTrimming="CharacterEllipsis" MaxLines="1" Margin="18,0,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Click="CancelReply_Click" Background="Transparent" BorderThickness="0" Padding="4">
                                        <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{StaticResource Current_TextGray}"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Background="{StaticResource Current_CardBackground}" Padding="20,16" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="0,1,0,0">
                            <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="0"/>
                                        <ColumnDefinition Width="Auto" MinWidth="0"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MessageTextBox"
                                         TextChanged="MessageTextBox_TextChanged"
                                         Grid.Column="0"
                                         PlaceholderText="Type your message..."
                                         PlaceholderForeground="{StaticResource Current_Placeholder}"
                                         PreviewKeyDown="MessageTextBox_PreviewKeyDown"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalAlignment="Top"
                                         VerticalContentAlignment="Top"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderThickness="1"
                                         BorderBrush="{StaticResource Current_BorderDark}"
                                         Background="{StaticResource Current_BackgroundDarker}"
                                         Foreground="{StaticResource Current_TextWhite}"
                                         CornerRadius="16"
                                         Padding="20,15"
                                         MinHeight="52"
                                         MaxHeight="240"
                                         FontSize="15"
                                         FontFamily="{StaticResource MainFont}"
                                         Opacity="0.95"
                                         HorizontalAlignment="Stretch">
                                        <TextBox.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Bold" Icon="Bold" Click="FormatBold_Click"/>
                                                <MenuFlyoutItem Text="Italic" Icon="Italic" Click="FormatItalic_Click"/>
                                                <MenuFlyoutItem Text="Strikethrough" Click="FormatStrikethrough_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xEDE0;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Cut" Icon="Cut" Click="FormatCut_Click"/>
                                                <MenuFlyoutItem Text="Copy" Icon="Copy" Click="FormatCopy_Click"/>
                                                <MenuFlyoutItem Text="Paste" Icon="Paste" Click="FormatPaste_Click"/>
                                            </MenuFlyout>
                                        </TextBox.ContextFlyout>
                                    <TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{Binding Color, Source={StaticResource Current_BackgroundDarker}}"/>
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                        <SolidColorBrush x:Key="TextControlForeground" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{Binding Color, Source={StaticResource Current_TextWhite}}"/>
                                    </TextBox.Resources>
                                </TextBox>
                                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="12,0,0,0" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="AttachButton"
                                            Click="AttachButton_Click"
                                            Background="Transparent"
                                            Foreground="{StaticResource Current_TextWhite}"
                                            CornerRadius="26"
                                            Height="52"
                                            Width="52"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource Current_BorderDark}"
                                            ToolTipService.ToolTip="Attach Image">
                                        <FontIcon Glyph="&#xE723;" FontSize="20"/>
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                                        </Button.Resources>
                                    </Button>
                                            <Button x:Name="CancelVoiceButton"
                                            Click="CancelVoiceButton_Click"
                                            Visibility="Collapsed"
                                            Background="Transparent"
                                            Foreground="#FF4444"
                                            CornerRadius="26"
                                            Height="52"
                                            Width="52"
                                            BorderThickness="1"
                                            BorderBrush="#FF4444"
                                            ToolTipService.ToolTip="Cancel Recording">
                                                <FontIcon Glyph="&#xE711;" FontSize="20"/>
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#22FF4444"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#44FF4444"/>
                                                </Button.Resources>
                                            </Button>
                                            <Button x:Name="VoiceButton"
                                            Click="VoiceButton_Click"
                                            Background="Transparent"
                                            Foreground="{StaticResource Current_TextWhite}"
                                            CornerRadius="26"
                                            Height="52"
                                            Width="52"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource Current_BorderDark}">
                                        <FontIcon x:Name="VoiceIcon" Glyph="&#xE720;" FontSize="20"/>
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                                        </Button.Resources>
                                    </Button>
                                    <Button x:Name="EmojiButton"
                                            Background="Transparent"
                                            Foreground="{StaticResource Current_TextWhite}"
                                            CornerRadius="26"
                                            Height="52"
                                            Width="52"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource Current_BorderDark}">
                                        <FontIcon Glyph="&#xE8ED;" FontSize="20"/>
                                                <Button.Flyout>
                                                    <Flyout x:Name="EmojiPickerFlyout" Placement="Top" ShowMode="Transient" Opening="EmojiPickerFlyout_Opening" Closing="EmojiPickerFlyout_Closing">
                                                        <Border Background="{StaticResource Current_CardBackground}" BorderThickness="0" CornerRadius="12" Padding="0" Width="440" Height="450">
                                                            <Pivot SelectedIndex="2">
                                                                <PivotItem>
                                                                    <PivotItem.Header>
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <FontIcon Glyph="&#xE76E;" FontSize="16"/>
                                                                            <TextBlock Text="Emoji" FontSize="14"/>
                                                                        </StackPanel>
                                                                    </PivotItem.Header>
                                                                    <GridView x:Name="EmojiListGrid" SelectionMode="None" Padding="12"  ScrollViewer.VerticalScrollBarVisibility="Auto" ItemTemplate="{StaticResource EmojiItemTemplate}" IsItemClickEnabled="True" ItemClick="EmojiListGrid_ItemClick">
                                                                        <GridView.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <ItemsWrapGrid Orientation="Horizontal" ItemWidth="48" ItemHeight="48" />
                                                                            </ItemsPanelTemplate>
                                                                        </GridView.ItemsPanel>
                                                                    </GridView>
                                                                </PivotItem>
                                                                <PivotItem>
                                                                    <PivotItem.Header>
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <FontIcon Glyph="&#xF4AA;" FontSize="16"/>
                                                                            <TextBlock Text="Stickers" FontSize="14"/>
                                                                        </StackPanel>
                                                                    </PivotItem.Header>

                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="90"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <ListView x:Name="StickerPacksList" Grid.Column="0" SelectionMode="Extended" IsItemClickEnabled="True" ItemClick="StickerPack_ItemClick" Padding="0,10,0,0" Background="{StaticResource Current_BackgroundDarker}">
                                                                            <ListView.ItemTemplate>
                                                                                <DataTemplate x:DataType="models:StickerPackModel">
                                                                                    <Grid Width="50" Height="50" Margin="0,6" HorizontalAlignment="Center" ToolTipService.ToolTip="{Binding Name}">
                                                                                        <Image Source="{Binding CoverImage}" Stretch="Uniform"/>
                                                                                    </Grid>
                                                                                </DataTemplate>
                                                                            </ListView.ItemTemplate>
                                                                        </ListView>
                                                                        <GridView x:Name="StickersGrid" Grid.Column="1" SelectionMode="None" Padding="10" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                                            <GridView.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="80" ItemHeight="80"/>
                                                                                </ItemsPanelTemplate>
                                                                            </GridView.ItemsPanel>
                                                                            <GridView.ItemTemplate>
                                                                                <DataTemplate x:DataType="models:StickerItemModel">
                                                                                    <Button Width="70" Height="70" Margin="4" Background="Transparent" BorderThickness="0" Click="StickerItem_Click" PointerEntered="StickerButton_PointerEntered" PointerExited="StickerButton_PointerExited" Tag="{x:Bind}">
                                                                                        <Image Source="{x:Bind Image, Mode=OneWay}" Stretch="Uniform"/>
                                                                                        <Button.Resources>
                                                                                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                                                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#22FFFFFF"/>
                                                                                        </Button.Resources>
                                                                                    </Button>
                                                                                </DataTemplate>
                                                                            </GridView.ItemTemplate>
                                                                        </GridView>
                                                                        <TextBlock x:Name="SelectPackText" Grid.Column="1" Text="Select a pack" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" Visibility="Visible"/>
                                                                    </Grid>
                                                                </PivotItem>
                                                                <PivotItem>
                                                                    <PivotItem.Header>
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <FontIcon Glyph="&#xF4A9;" FontSize="16"/>
                                                                            <TextBlock Text="GIFs" FontSize="14"/>
                                                                        </StackPanel>
                                                                    </PivotItem.Header>
                                                                    <GridView x:Name="EmojiGrid" SelectionMode="None" Padding="12" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollMode="Disabled">
                                                                        <GridView.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <ItemsWrapGrid Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </GridView.ItemsPanel>
                                                                        <GridView.ItemTemplate>
                                                                            <DataTemplate x:DataType="local:GifPickerItem">
                                                                                <Button Width="110" Height="110" Margin="4" Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource Current_BorderDark}" Click="GifItemButton_Click" Tag="{Binding Filename}">
                                                                                    <Image Source="{Binding Image}" Width="110" Height="110" Stretch="Uniform"/>

                                                                                    <Button.Resources>
                                                                                        <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                                                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                                                                                    </Button.Resources>
                                                                                </Button>
                                                                            </DataTemplate>
                                                                        </GridView.ItemTemplate>
                                                                    </GridView>
                                                                </PivotItem>
                                                            </Pivot>
                                                        </Border>
                                                    </Flyout>
                                                </Button.Flyout>
                                                <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource Current_BorderDark}}"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource Current_BackgroundDark}}"/>
                                        </Button.Resources>
                                    </Button>
                                    <Button x:Name="SendButton"
                                            Click="SendButton_Click"
                                            Background="{StaticResource PrimaryGreen}"
                                            Foreground="White"
                                            CornerRadius="26"
                                            Height="52"
                                            Width="52"
                                            BorderThickness="0">
                                        <FontIcon Glyph="&#xE725;" FontSize="20" Foreground="White"/>

                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackground" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{Binding Color, Source={StaticResource PrimaryGreen}}"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{Binding Color, Source={StaticResource DarkGreen}}"/>
                                            <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
            <Grid x:Name="EditProfileOverlay" Visibility="Collapsed" Canvas.ZIndex="200">
                <Border Background="#99000000" Tapped="CloseOverlays_Tapped"/>

                <Border Background="{StaticResource Current_CardBackground}" 
            CornerRadius="12" Width="500" MaxHeight="600" 
            HorizontalAlignment="Center" VerticalAlignment="Center" 
            BorderBrush="{StaticResource Current_BorderDark}" 
            BorderThickness="1" Padding="24">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="20">
                            <TextBlock Text="Edit Profile" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource Current_TextWhite}" 
                           HorizontalAlignment="Center" FontFamily="{StaticResource MainFont}"/>

                            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                                <Grid Width="100" Height="100" CornerRadius="50">
                                    <Ellipse x:Name="EditAvatarPreview" Fill="{StaticResource PrimaryGreen}"/>
                                    <Image x:Name="EditAvatarImage" Stretch="UniformToFill"/>
                                </Grid>
                                <StackPanel Spacing="10" VerticalAlignment="Center">
                                    <Button Content="Upload Photo" Click="UploadPhoto_Click" 
                                CornerRadius="8" Background="{StaticResource PrimaryGreen}" Foreground="White"/>

                                    <Button Content="Remove Photo" Click="RemovePhoto_Click" 
                                CornerRadius="8" Background="Transparent" 
                                Foreground="{StaticResource Current_TextWhite}" 
                                BorderBrush="{StaticResource Current_BorderDark}" 
                                BorderThickness="1"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="EditLoginText" HorizontalAlignment="Center" Foreground="{StaticResource Current_TextGray}" FontSize="14" Margin="0,5,0,10" FontFamily="{StaticResource MainFont}"/>
                            <TextBox x:Name="EditUsernameBox" Header="Username" PlaceholderText="New username"/>
                            <TextBox x:Name="EditBioBox" Header="Bio" PlaceholderText="About you" 
                         Height="100" AcceptsReturn="True" TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                                <Button Content="Cancel" Click="CancelEdit_Click"/>
                                <Button Content="Save" Click="SaveProfile_Click" Background="{StaticResource PrimaryGreen}" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid x:Name="CropOverlay" Visibility="Collapsed" Canvas.ZIndex="300">
                <Border Background="#CC000000"/>

                <Grid Background="{StaticResource Current_CardBackground}" 
          CornerRadius="12" Padding="20" Width="600" Height="600"
          HorizontalAlignment="Center" VerticalAlignment="Center"
          BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Crop Image" FontSize="20" FontWeight="Bold" 
                   Foreground="White" Margin="0,0,0,10"/>

                    <controls:ImageCropper x:Name="ProfileCropper" 
                               Grid.Row="1" 
                               AspectRatio="1" 
                               CropShape="Circular"
                               ThumbPlacement="Corners"
                               Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Spacing="10">
                        <Button Content="Cancel" Click="CancelCrop_Click"/>
                        <Button Content="Save Crop" Click="ConfirmCrop_Click" 
                    Background="{StaticResource PrimaryGreen}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid x:Name="SettingsOverlay" Visibility="Collapsed" Canvas.ZIndex="200">
                <Border Background="#99000000" Tapped="CloseOverlays_Tapped"/>

                <Border Background="{StaticResource Current_CardBackground}" 
            CornerRadius="12" Width="500" MaxHeight="600" 
            HorizontalAlignment="Center" VerticalAlignment="Center" 
            BorderBrush="{StaticResource Current_BorderDark}" 
            BorderThickness="1" Padding="24">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Settings" FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource Current_TextWhite}" 
                       Margin="0,0,0,20" FontFamily="{StaticResource MainFont}"/>

                        <ScrollViewer Grid.Row="1">
                            <Frame x:Name="SettingsFrame"/>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,20,0,0">
                            <Button Content="Cancel" Click="SettingsPopup_Cancel"/>
                            <Button Content="Save" Click="SettingsPopup_Save" Background="{StaticResource PrimaryGreen}" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                
                </Border>
            
            </Grid>
            <Grid x:Name="UserProfileOverlay" Visibility="Collapsed" Canvas.ZIndex="200">
                <Border Background="#99000000" Tapped="CloseOverlays_Tapped"/>
                <Border Background="{StaticResource Current_CardBackground}" CornerRadius="12" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1" Padding="24">
                    <StackPanel Spacing="20">
                        <Grid Width="100" Height="100" CornerRadius="50">
                            <Ellipse x:Name="ViewUserEllipse" Fill="{StaticResource PrimaryGreen}"/>
                            <TextBlock x:Name="ViewUserInitials" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ViewUserImage" Stretch="UniformToFill"/>
                        </Grid>
                        <TextBlock x:Name="ViewUserUsername" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Current_TextWhite}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ViewUserLogin" FontSize="16" Foreground="{StaticResource Current_TextGray}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ViewUserBio" FontSize="14" Foreground="{StaticResource Current_TextGray}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <Button Content="Close" Click="CloseOverlays_Click" HorizontalAlignment="Center" Background="{StaticResource Current_SidebarButtonBackground}" Foreground="{StaticResource Current_TextWhite}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="GroupProfileOverlay" Visibility="Collapsed" Canvas.ZIndex="200">
                <Border Background="#99000000" Tapped="CloseOverlays_Tapped"/>

                <Border Background="{StaticResource Current_CardBackground}" 
                    CornerRadius="12" 
                    Width="500" 
                    MaxHeight="600" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    BorderBrush="{StaticResource Current_BorderDark}" 
                    BorderThickness="1" 
                    Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,15">

                            <Grid HorizontalAlignment="Center">
                                <Grid Width="100" Height="100" CornerRadius="50">
                                    <Ellipse x:Name="GroupAvatarBg" Fill="{StaticResource PrimaryGreen}"/>
                                    <Image x:Name="GroupAvatarImage" Stretch="UniformToFill"/>
                                    <TextBlock x:Name="GroupInitials" Text="G" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="36" FontWeight="Bold"/>
                                </Grid>

                                <Button x:Name="GroupUploadPhotoButton" Click="GroupUploadPhoto_Click" 
                                    VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,-10,0"
                                    CornerRadius="15" Width="30" Height="30" Padding="0"
                                    Background="{StaticResource Current_CardBackground}" BorderBrush="{StaticResource Current_BorderDark}" BorderThickness="1"
                                    Visibility="Collapsed">
                                    <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="{StaticResource Current_TextWhite}"/>
                                </Button>

                                <Button x:Name="GroupRemovePhotoButton" Click="GroupRemovePhoto_Click" 
                                    VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="-10,0,0,0"
                                    CornerRadius="15" Width="30" Height="30" Padding="0"
                                    Background="#FF4444" BorderThickness="0"
                                    Visibility="Collapsed">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="White"/>
                                </Button>
                            </Grid>
                            <TextBox x:Name="GroupNameBox" HorizontalAlignment="Stretch" TextAlignment="Center"
                                 Background="Transparent" BorderThickness="0" FontSize="20" FontWeight="Bold"
                                 Foreground="{StaticResource Current_TextWhite}" PlaceholderText="Group Name"/>

                            <TextBlock x:Name="GroupMemberCount" Foreground="{StaticResource Current_TextGray}" HorizontalAlignment="Center" FontSize="12"/>

                            <Button x:Name="GroupSaveButton" Content="Save Changes" Click="GroupSave_Click" 
                                HorizontalAlignment="Center" Background="{StaticResource PrimaryGreen}" Foreground="White"
                                Visibility="Collapsed"/>
                        </StackPanel>

                        <ListView x:Name="GroupMembersListView" Grid.Row="1" SelectionMode="None" 
                              BorderThickness="1" BorderBrush="{StaticResource Current_BorderDark}" 
                              CornerRadius="4" Background="{StaticResource Current_BackgroundDarker}"
                              Height="300">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:UserItemModel">
                                    <Grid Padding="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="32" Height="32" CornerRadius="16">
                                            <Ellipse Fill="{Binding AvatarColor}"/>
                                            <TextBlock Text="{Binding Initials}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                            <Image Source="{Binding ProfileImage}" Stretch="UniformToFill"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" Spacing="6">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Current_TextWhite}" FontWeight="SemiBold" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal" Spacing="0">
                                                <TextBlock Text="@" Foreground="{StaticResource Current_TextGray}" FontSize="13"/>
                                                <TextBlock Text="{Binding Username}" Foreground="{StaticResource Current_TextGray}" FontSize="13"/>
                                            </StackPanel>
                                            
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="Kick" 
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Click="KickMember_Click" Tag="{Binding Id}"
                                            Background="Transparent" Foreground="#FF4444" BorderThickness="0"
                                            FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel x:Name="GroupAdminPanel" Grid.Row="2" Margin="0,15,0,0" Visibility="Collapsed" Spacing="10">
                            <TextBlock Text="Admin Controls" FontWeight="Bold" Foreground="{StaticResource Current_TextGray}"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBox x:Name="GroupAddMemberBox" PlaceholderText="Enter @tag to add" Width="250" 
                                     Background="{StaticResource Current_BackgroundDarker}" Foreground="{StaticResource Current_TextWhite}" BorderBrush="{StaticResource Current_BorderDark}"/>
                                <Button Content="Add" Click="GroupAddMember_Click" Background="{StaticResource PrimaryGreen}" Foreground="White"/>
                            </StackPanel>
                            <Button Content="Delete Group" Click="GroupDelete_Click" Background="#FF4444" Foreground="White" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <Button Grid.Row="2" x:Name="GroupCloseButton" Content="Close" Click="CloseOverlays_Click" 
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,15,0,0"
                            Background="Transparent" Foreground="{StaticResource Current_TextGray}"/>
                    </Grid>
                </Border>
            </Grid>
            <!-- Sticker Preview Overlay -->
            <Grid x:Name="StickerPreviewOverlay" Visibility="Collapsed" Background="#80000000" Canvas.ZIndex="10000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Image x:Name="StickerPreviewImage" Width="500" Height="500" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" />
            </Grid>
            <Grid x:Name="ImagePreviewOverlay" Visibility="Collapsed" Canvas.ZIndex="5000" Background="#F2000000">
                <Grid.Transitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20" IsStaggeringEnabled="False"/>
                    </TransitionCollection>
                </Grid.Transitions>
                <ScrollViewer x:Name="ImagePreviewScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ZoomMode="Enabled" MinZoomFactor="0.1" MaxZoomFactor="5.0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <Image x:Name="FullSizeImage" Stretch="None" RenderTransformOrigin="0.5,0.5" Tapped="ImageOverlay_Tapped"/>
                </ScrollViewer>
                <Grid VerticalAlignment="Top" Padding="20" Background="#66000000">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ImageFileNameText" Text="Image" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Click="SaveFullImage_Click" Background="Transparent" Foreground="White" BorderThickness="0" ToolTipService.ToolTip="Save">
                            <FontIcon Glyph="&#xE74E;" />
                        </Button>
                        <Button Click="CloseImagePreview_Click" Background="Transparent" Foreground="White" BorderThickness="0" ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Viewbox>
</Page>