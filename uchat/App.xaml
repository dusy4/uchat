<Application
    x:Class="uchat.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="/Themes/Windows7Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="PrimaryGreen" Color="#4CAF50"/>
            <SolidColorBrush x:Key="DarkGreen" Color="#388E3C"/>
            <SolidColorBrush x:Key="HighlightGreenSubtle" Color="#334CAF50"/>
            <SolidColorBrush x:Key="HighlightGreenSelected" Color="#664CAF50"/>
            <SolidColorBrush x:Key="DangerRed" Color="#F44336"/>

            <FontFamily x:Key="MainFont">Segoe UI Variable Display</FontFamily>
            <FontFamily x:Key="EmojiFont">ms-appx:///Assets/fonts/Memetica.ttf#Memetica</FontFamily>

            <Color x:Key="Dark_BackgroundDarkColor">#1A1A1A</Color>
            <Color x:Key="Dark_BackgroundDarkerColor">#0F0F0F</Color>
            <Color x:Key="Dark_CardBackgroundColor">#141918</Color>
            <Color x:Key="Dark_SidebarBackgroundColor">#0F1413</Color>
            <Color x:Key="Dark_TextWhiteColor">#FFFFFF</Color>
            <Color x:Key="Dark_TextGrayColor">#8B9A95</Color>
            <Color x:Key="Dark_BorderDarkColor">#2A2A2A</Color>
            <Color x:Key="Dark_MessageBubbleOwnColor">#1E2F20</Color>
            <Color x:Key="Dark_MessageBubbleOtherColor">#242424</Color>
            <Color x:Key="Dark_PlaceholderColor">#8B9A95</Color>
            <Color x:Key="Dark_SidebarButtonBackgroundColor">#141918</Color>
            <Color x:Key="Dark_SystemMessageColor">#422D64</Color>

            <Color x:Key="Light_BackgroundDarkColor">#F5F7F9</Color>
            <Color x:Key="Light_BackgroundDarkerColor">#FFFFFF</Color>
            <Color x:Key="Light_CardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="Light_SidebarBackgroundColor">#EEF0F2</Color>
            <Color x:Key="Light_TextWhiteColor">#111111</Color>
            <Color x:Key="Light_TextGrayColor">#666666</Color>
            <Color x:Key="Light_BorderDarkColor">#D1D9E6</Color>
            <Color x:Key="Light_MessageBubbleOwnColor">#DCF8C6</Color>
            <Color x:Key="Light_MessageBubbleOtherColor">#FFFFFF</Color>
            <Color x:Key="Light_PlaceholderColor">#666666</Color>
            <Color x:Key="Light_SidebarButtonBackgroundColor">#FFFFFF</Color>
            <Color x:Key="Light_SystemMessageColor">#E0E0E0</Color>

            <SolidColorBrush x:Key="Current_SystemMessage" Color="{StaticResource Dark_SystemMessageColor}"/>
            <SolidColorBrush x:Key="Current_BackgroundDark" Color="{StaticResource Dark_BackgroundDarkColor}"/>
            <SolidColorBrush x:Key="Current_BackgroundDarker" Color="{StaticResource Dark_BackgroundDarkerColor}"/>
            <SolidColorBrush x:Key="Current_CardBackground" Color="{StaticResource Dark_CardBackgroundColor}"/>
            <SolidColorBrush x:Key="Current_SidebarBackground" Color="{StaticResource Dark_SidebarBackgroundColor}"/>
            <SolidColorBrush x:Key="Current_TextWhite" Color="{StaticResource Dark_TextWhiteColor}"/>
            <SolidColorBrush x:Key="Current_TextGray" Color="{StaticResource Dark_TextGrayColor}"/>
            <SolidColorBrush x:Key="Current_BorderDark" Color="{StaticResource Dark_BorderDarkColor}"/>
            <SolidColorBrush x:Key="Current_MessageBubbleOwn" Color="{StaticResource Dark_MessageBubbleOwnColor}"/>
            <SolidColorBrush x:Key="Current_MessageBubbleOther" Color="{StaticResource Dark_MessageBubbleOtherColor}"/>
            <SolidColorBrush x:Key="Current_Placeholder" Color="{StaticResource Dark_PlaceholderColor}"/>
            <SolidColorBrush x:Key="Current_SidebarButtonBackground" Color="{StaticResource Dark_SidebarButtonBackgroundColor}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
