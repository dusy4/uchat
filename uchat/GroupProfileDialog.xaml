<ContentDialog
    x:Class="uchat.GroupProfileDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:uchat"
    xmlns:models="using:uchat.Models"
    Title="Group Info"
    PrimaryButtonText="Close"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#4CAF50"/>
    </ContentDialog.Resources>
    <Grid MinWidth="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
            <TextBlock x:Name="GroupNameText" FontSize="20" FontWeight="Bold"/>
            <TextBlock x:Name="MembersCountText" Foreground="Gray"/>
        </StackPanel>

        <ListView x:Name="MembersList" Grid.Row="1" Height="250" SelectionMode="None" BorderThickness="1" BorderBrush="#333" CornerRadius="4">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:UserItemModel">
                    <Grid Padding="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="32" Height="32" CornerRadius="16">
                            <Ellipse Fill="{Binding AvatarColor}"/>
                            <TextBlock Text="{Binding Initials}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            <Image Source="{Binding ProfileImage}" Stretch="UniformToFill"/>
                        </Grid>

                        <TextBlock Grid.Column="1" Text="{Binding Username}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>

                        <Button Grid.Column="2" Content="Kick" 
                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="KickMember_Click" Tag="{Binding Id}"
                                Background="Transparent" Foreground="#FF4444" BorderThickness="0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel x:Name="AdminPanel" Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,15,0,0" Visibility="Collapsed">
            <TextBox x:Name="NewMemberBox" PlaceholderText="Enter username to add" Width="250"/>
            <Button Content="Add" Click="AddMember_Click" Background="{StaticResource PrimaryGreen}" Foreground="White"/>
            <Button x:Name="DeleteGroupButton" Content="Delete Group" Click="DeleteGroup_Click" Background="#FF4444" Foreground="White" HorizontalAlignment="Stretch" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</ContentDialog>