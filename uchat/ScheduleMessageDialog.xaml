<ContentDialog
    x:Class="uchat.ScheduleMessageDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Schedule Message"
    PrimaryButtonText="Schedule"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    Width="500">

    <ContentDialog.Resources>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#4CAF50"/>
        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextGray" Color="#8B9A95"/>
        <SolidColorBrush x:Key="CardBackground" Color="#141918"/>
        <SolidColorBrush x:Key="BackgroundDarker" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2A2A2A"/>
        <FontFamily x:Key="MainFont">Segoe UI Variable Display</FontFamily>
    </ContentDialog.Resources>

    <Grid Padding="24" Background="{StaticResource CardBackground}">
        <StackPanel Spacing="20">
            <TextBlock Text="Message:" 
                      Foreground="{StaticResource TextGray}" 
                      FontSize="13"
                      FontFamily="{StaticResource MainFont}"/>
            <TextBox x:Name="MessageTextBox" 
                    TextWrapping="Wrap" 
                    AcceptsReturn="True" 
                    Height="100"
                    Background="{StaticResource BackgroundDarker}" 
                    Foreground="{StaticResource TextWhite}" 
                    BorderThickness="1" 
                    BorderBrush="{StaticResource BorderDark}" 
                    CornerRadius="8"
                    Padding="12,10"
                    FontSize="14"
                    FontFamily="{StaticResource MainFont}">
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#0F0F0F"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#4CAF50"/>
                    <SolidColorBrush x:Key="TextControlForeground" Color="#FFFFFF"/>
                </TextBox.Resources>
            </TextBox>

            <TextBlock Text="Schedule Date &amp; Time:" 
                      Foreground="{StaticResource TextGray}" 
                      FontSize="13"
                      FontFamily="{StaticResource MainFont}"/>
            <CalendarDatePicker x:Name="DatePicker"
                               HorizontalAlignment="Stretch"
                               FontSize="14"
                               FontFamily="{StaticResource MainFont}"/>

            <TimePicker x:Name="TimePicker"
                       HorizontalAlignment="Stretch"
                       FontSize="14"
                       FontFamily="{StaticResource MainFont}"/>
        </StackPanel>
    </Grid>
</ContentDialog>

