<ContentDialog
    x:Class="uchat.PlannedMessagesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:uchat"
    Title="Planned Messages"
    PrimaryButtonText="Close"
    DefaultButton="Primary"
    Width="600"
    MaxHeight="600">

    <ContentDialog.Resources>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#4CAF50"/>
        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextGray" Color="#8B9A95"/>
        <SolidColorBrush x:Key="CardBackground" Color="#141918"/>
        <SolidColorBrush x:Key="BackgroundDarker" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2A2A2A"/>
        <FontFamily x:Key="MainFont">Segoe UI Variable Display</FontFamily>
    </ContentDialog.Resources>

    <Grid Padding="24" Background="{StaticResource CardBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
            <ListView x:Name="ScheduledMessagesList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ScheduledMessageViewModel">
                        <Border Background="{StaticResource BackgroundDarker}" 
                               CornerRadius="8" 
                               Padding="16" 
                               Margin="0,0,0,12"
                               BorderBrush="{StaticResource BorderDark}" 
                               BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" 
                                          Text="{Binding Content}" 
                                          FontSize="14" 
                                          Foreground="{StaticResource TextWhite}" 
                                          TextWrapping="Wrap"
                                          FontFamily="{StaticResource MainFont}"
                                          Margin="0,0,0,8"/>
                                
                                <TextBlock Grid.Row="1" 
                                          Text="{Binding ScheduledAtDisplay}" 
                                          FontSize="12" 
                                          Foreground="{StaticResource TextGray}" 
                                          FontFamily="{StaticResource MainFont}"
                                          Margin="0,0,0,8"/>
                                
                                <StackPanel Grid.Row="2" 
                                           Orientation="Horizontal" 
                                           Spacing="8">
                                    <Button Content="Edit" 
                                           Tag="{Binding Id}"
                                           Background="{StaticResource PrimaryGreen}"
                                           Foreground="{StaticResource TextWhite}"
                                           BorderThickness="0"
                                           CornerRadius="6"
                                           Padding="16,8"
                                           FontSize="13"
                                           FontFamily="{StaticResource MainFont}">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackground" Color="#4CAF50"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5FBF62"/>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="Delete" 
                                           Tag="{Binding Id}"
                                           Background="{StaticResource BackgroundDarker}"
                                           Foreground="{StaticResource TextWhite}"
                                           BorderBrush="{StaticResource BorderDark}"
                                           BorderThickness="1"
                                           CornerRadius="6"
                                           Padding="16,8"
                                           FontSize="13"
                                           FontFamily="{StaticResource MainFont}">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackground" Color="#0F0F0F"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2A2A2A"/>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</ContentDialog>

